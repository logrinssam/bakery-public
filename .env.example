GEMINI_API_KEY="MY_GEMINI_API_KEY"

# 공개 URL (OG 미리보기·canonical, 빌드 시 index.html에 주입)
VITE_PUBLIC_APP_URL="https://pixel-bakery.xn--9d0blmm1xg2knrf.com"

# Firebase 콘솔 > Authentication > Settings > Authorized domains 에 추가:
#   pixel-bakery.xn--9d0blmm1xg2knrf.com
#   bakery.iirii.workers.dev
# (로그인교실 한글 도메인은 punycode 로 등록)

