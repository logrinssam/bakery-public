# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# 초등학교 목록 (권장): data/elementary-schools.csv 넣고 한 번만 실행
# npm run build:schools
# → public/data/elementary-schools.json 생성 후 GitHub에 함께 올리기

# Firebase — Firebase 콘솔 > 프로젝트 설정 > 웹 앱
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Realtime Database (학교망에서 Firestore 막힐 때 이어하기·집계 백업)
# Firebase 콘솔 > Realtime Database > 만들기 후 URL 복사
# Realtime Database > 데이터 탭 상단 URL 그대로 복사 (필수)
# VITE_FIREBASE_DATABASE_URL="https://pixelbakery-a3ffb-default-rtdb.asia-southeast1.firebasedatabase.app"

# 집계 확인: Firestore 또는 Realtime Database 둘 다
# pinSaves(이어하기), meta/stats, schoolStats, visitors, meta/schools
