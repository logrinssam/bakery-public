# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# 초등학교 목록 (권장): data/elementary-schools.csv 넣고 한 번만 실행
# npm run build:schools
# → public/data/elementary-schools.json 생성 후 GitHub에 함께 올리기

# Firebase — Firebase 콘솔 > 프로젝트 설정 > 웹 앱
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# 접속·학교 통계는 앱 UI 없이 Firebase 콘솔 > Firestore에서 확인
# (meta/stats, schoolStats, schoolUsers, hallRecords, pinSaves 등)
