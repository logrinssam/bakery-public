rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /pinSaves/{saveId} {
      allow read, write: if request.auth != null
        && saveId.size() >= 32
        && saveId.size() <= 64
        && isValidPlayerSave(request.resource.data);
    }

    match /schoolStats/{schoolId} {
      allow read: if true;
      allow create: if isValidSchoolStatsCreate(request.resource.data);
      allow update: if isValidSchoolStatsUpdate(request.resource.data);
      allow delete: if false;
    }

    match /schoolVisitors/{schoolId}/devices/{deviceId} {
      allow read: if false;
      allow create: if deviceId.size() >= 8
        && deviceId.size() <= 64
        && request.resource.data.keys().hasOnly(['deviceId', 'firstSeen'])
        && request.resource.data.deviceId == deviceId;
      allow update, delete: if false;
    }

    match /hallRecords/{recordId} {
      allow read: if true;
      allow create: if isValidHallRecord(request.resource.data);
      allow update, delete: if false;
    }

    match /visitors/{deviceId} {
      allow read: if true;
      allow create: if deviceId.size() >= 8
        && deviceId.size() <= 64
        && request.resource.data.keys().hasOnly(['deviceId', 'firstSeen'])
        && request.resource.data.deviceId == deviceId;
      allow update, delete: if false;
    }

    match /meta/stats {
      allow read: if true;
      allow create: if isValidStatsCreate(request.resource.data);
      allow update: if isValidStatsUpdate(request.resource.data);
      allow delete: if false;
    }
  }
}

function isValidPlayerSave(data) {
  return data.keys().hasOnly([
      'stageProgress',
      'gold',
      'streakCount',
      'highestStreak',
      'starsEarned',
      'correctAnswersCount',
      'totalAnswersCount',
      'purchasedEquipmentIds',
      'hallOfFameRegistered',
      'hallName',
      'hallSchool',
      'hallComment',
      'hallDate',
      'unlockedBreadIndices',
      'encounteredMascotNames',
      'updatedAt'
    ])
    && data.stageProgress is int && data.stageProgress >= 1 && data.stageProgress <= 50
    && data.gold is int && data.gold >= 0 && data.gold <= 9999999
    && data.streakCount is int && data.streakCount >= 0 && data.streakCount <= 9999
    && data.highestStreak is int && data.highestStreak >= 0 && data.highestStreak <= 9999
    && data.starsEarned is int && data.starsEarned >= 0 && data.starsEarned <= 999999
    && data.correctAnswersCount is int && data.correctAnswersCount >= 0 && data.correctAnswersCount <= 999999
    && data.totalAnswersCount is int && data.totalAnswersCount >= 0 && data.totalAnswersCount <= 999999
    && data.hallOfFameRegistered is bool;
}

function isValidHallRecord(data) {
  return data.keys().hasOnly([
      'name', 'schoolName', 'comment', 'date', 'stars', 'highestStreak', 'createdAt'
    ])
    && data.name is string
    && data.name.size() >= 1
    && data.name.size() <= 30
    && data.schoolName is string
    && data.schoolName.size() >= 2
    && data.schoolName.size() <= 80
    && data.comment is string
    && data.comment.size() >= 1
    && data.comment.size() <= 200
    && data.date is string
    && data.date.size() >= 8
    && data.date.size() <= 12
    && data.stars is int
    && data.stars >= 0
    && data.stars <= 600
    && data.highestStreak is int
    && data.highestStreak >= 0
    && data.highestStreak <= 100
    && data.createdAt is string
    && data.createdAt.size() >= 10
    && data.createdAt.size() <= 40;
}

function isValidStatsCreate(data) {
  return data.keys().hasOnly(['totalSessions', 'uniqueDevices', 'updatedAt'])
    && data.totalSessions == 1
    && data.uniqueDevices == 0;
}

function isValidStatsUpdate(data) {
  return data.keys().hasAll(['totalSessions', 'uniqueDevices'])
    && data.totalSessions is int
    && data.uniqueDevices is int
    && data.totalSessions >= resource.data.totalSessions
    && data.totalSessions <= resource.data.totalSessions + 1
    && data.uniqueDevices >= resource.data.uniqueDevices
    && data.uniqueDevices <= resource.data.uniqueDevices + 1;
}

function isValidSchoolStatsCreate(data) {
  return data.keys().hasOnly(['schoolName', 'totalSessions', 'uniqueDevices', 'updatedAt'])
    && data.schoolName is string
    && data.schoolName.size() >= 2
    && data.schoolName.size() <= 80
    && data.totalSessions == 1
    && data.uniqueDevices == 0;
}

function isValidSchoolStatsUpdate(data) {
  return data.keys().hasAll(['schoolName', 'totalSessions', 'uniqueDevices'])
    && data.schoolName == resource.data.schoolName
    && data.totalSessions is int
    && data.uniqueDevices is int
    && data.totalSessions >= resource.data.totalSessions
    && data.totalSessions <= resource.data.totalSessions + 1
    && data.uniqueDevices >= resource.data.uniqueDevices
    && data.uniqueDevices <= resource.data.uniqueDevices + 1;
}
